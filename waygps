server {
    listen 80;
    server_name gastoncelentano.com.ar www.gastoncelentano.com.ar 200.58.98.187;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name gastoncelentano.com.ar www.gastoncelentano.com.ar 200.58.98.187;

    ssl_certificate /etc/letsencrypt/live/gastoncelentano.com.ar/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/gastoncelentano.com.ar/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location /static/ {
        alias /opt/miapp/staticfiles/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    
        # Especificar Content-Type para archivos JavaScript
        location ~* \.js$ {
            add_header Content-Type "application/javascript; charset=utf-8";
        }
    
        # Especificar Content-Type para archivos CSS
        location ~* \.css$ {
            add_header Content-Type "text/css; charset=utf-8";
        }
    }

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
       # NO cachear HTML - forzar recarga siempre
       add_header Cache-Control "no-cache, no-store, must-revalidate";
       add_header Pragma "no-cache";
       add_header Expires "0";    }


     location = /logs {
	  return 301 /logs/;
	}

    location /logs/ {
        proxy_pass http://127.0.0.1:8088;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
       # NO cachear HTML - forzar recarga siempre
       add_header Cache-Control "no-cache, no-store, must-revalidate";
       add_header Pragma "no-cache";
       add_header Expires "0";    }

    location = /admin {
	  return 301 /admin/;
	}

    location /admin/ {
	  proxy_pass http://127.0.0.1:8090/;
	  proxy_set_header Host $host;
	  proxy_set_header X-Real-IP $remote_addr;
	  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
	  proxy_set_header X-Forwarded-Proto $scheme;
	}


}
